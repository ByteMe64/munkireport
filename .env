# ==========================================
# MunkiReport Docker Environment Variables
# ==========================================

# The external hostname or IP address clients will use to connect to MunkiReport
# Example: munkireport.yourdomain.com or 192.168.1.50
MR_HOST=munkireport.local

# ==========================================
# Database Security Credentials
# ==========================================

# The absolute root password for the MariaDB instance. 
# Make this exceptionally long and complex. You will rarely need to use it.
DB_ROOT_PASSWORD=ChangeThisToASuperSecureRootPassword!

# The password specifically for the 'munkiuser' to access the 'munkireport' database.
# This is the password the PHP app will use to talk to the database.
DB_PASSWORD=ChangeThisToASecureMunkiAppPassword!
