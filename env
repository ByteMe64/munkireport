# =============================================================================
# MunkiReport Stack — Environment Variables
# =============================================================================
# Fill in all CHANGE_ME values before deploying.
# NEVER commit this file to version control — add it to .gitignore.
# In Portainer: paste these key=value pairs into the Stack environment UI.
# =============================================================================

# -----------------------------------------------------------------------------
# Version pins — change a value here and rebuild to upgrade any component.
# -----------------------------------------------------------------------------
PHP_VERSION=8.3
MARIADB_VERSION=11.4
MUNKIREPORT_VERSION=5.8.0
BUSYBOX_VERSION=1.37

# -----------------------------------------------------------------------------
# Site — must match the URL browsers and Mac clients use to reach MunkiReport.
# -----------------------------------------------------------------------------
WEBHOST=https://munkireport.yourdomain.com
SITENAME=MunkiReport

# -----------------------------------------------------------------------------
# Database — MYSQL_PASSWORD and CONNECTION_PASSWORD must be identical.
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
CONNECTION_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_DATABASE=munkireport
MYSQL_USER=munkireport

# -----------------------------------------------------------------------------
# Admin user
# The hash below is phpass format (starts with $P$) for the password "admin".
# Change this before going live.
#
# To generate a new phpass hash run this AFTER the stack is first up:
#   docker exec -it munkireport php -r "
#     require '/var/munkireport/vendor/autoload.php';
#     \$h = new PasswordHash(8, false);
#     echo \$h->HashPassword('yournewpassword') . PHP_EOL;
#   "
# Paste the result as ADMIN_PASSWORD_HASH, then run:
#   docker compose down && docker volume rm munkireport-users && docker compose up -d
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_REALNAME=Administrator
ADMIN_PASSWORD_HASH=$P$BVRRqgBtBOrmY9uhku19E4AA.Mg2ZF0

# -----------------------------------------------------------------------------
# Modules
# -----------------------------------------------------------------------------
MUNKIREPORT_MODULES=disk_report,managedinstalls,munkireport,munkireportinfo,applications,inventory,network,security,filevault_status,softwareupdate,displays_info,installhistory,user_sessions,mdm_status,power,wifi

# -----------------------------------------------------------------------------
# Port — use 127.0.0.1:8080 when sitting behind a reverse proxy (recommended).
# -----------------------------------------------------------------------------
HOST_PORT=127.0.0.1:8080

# -----------------------------------------------------------------------------
# Migrations — set to FALSE after initial deploy. Re-enable for upgrades.
# -----------------------------------------------------------------------------
ALLOW_MIGRATIONS=TRUE
