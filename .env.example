# =============================================================================
# MunkiReport Environment Configuration — Example / Template
# Copy this file to .env and fill in real values before deploying.
# =============================================================================

# Image versions
MARIADB_VERSION=11.4
BUSYBOX_VERSION=latest

# Database
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=munkireport
MYSQL_USER=munkireport
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD

# MunkiReport
SITENAME=MunkiReport

# Reverse proxy / TLS
# DOMAIN must have a public DNS A record pointing at this server
DOMAIN=munkireport.yourdomain.com
ACME_EMAIL=admin@example.com

# Client authentication — Mac clients must set this passphrase in their config
CLIENT_PASSPHRASE=CHANGE_ME_CLIENT_PASSPHRASE
